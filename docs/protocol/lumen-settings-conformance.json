{
  "schemaVersion": 1,
  "protocol": "lumen-settings",
  "networkTransport": {
    "scheme": "https",
    "contentType": "application/json",
    "maximumRequestBytes": 32768,
    "authentication": "lumen-device-bearer-v1",
    "routes": {
      "snapshot": {"method": "GET", "path": "/api/v1/settings"},
      "patch": {"method": "PATCH", "path": "/api/v1/settings"},
      "events": {"method": "GET", "path": "/api/v1/settings/events", "resumeQuery": "afterRevision"}
    }
  },
  "envelopes": {
    "snapshot": ["schemaVersion", "revision", "settings", "effective", "applyState", "capabilities"],
    "patchRequest": ["schemaVersion", "baseRevision", "requestId", "changes"],
    "patchResponse": ["schemaVersion", "revision", "accepted", "effective", "applyState", "requires"],
    "event": ["schemaVersion", "revision", "settings", "effective", "applyState"]
  },
  "applyStates": ["applied", "pending-next-session", "pending-worker-restart"],
  "applyClasses": ["live", "next-session", "worker-restart"],
  "requires": ["none", "next-session", "worker-restart"],
  "errorCodes": [
    "unsupported-schema", "invalid-request", "unknown-field", "forbidden-field",
    "unavailable-field", "invalid-value", "stale-revision", "request-id-conflict",
    "revision-not-retained", "storage-error", "corrupt-data"
  ],
  "requestId": {"minimumLength": 1, "maximumLength": 128, "encoding": "non-whitespace-ascii"},
  "retention": {"events": 128, "idempotencyRecords": 256},
  "commandContract": {
    "execution": "argv-without-shell",
    "privileges": ["user", "administrator"],
    "maximumEntriesPerList": 64,
    "maximumArgumentsPerInvocation": 64,
    "maximumArgumentLength": 1024,
    "programPattern": "^[A-Za-z0-9._-]+$"
  },
  "forbiddenRemoteKeys": [
    "applicationsFilePath",
    "accessToken",
    "certificatePath",
    "controlLocation",
    "credentialsFilePath",
    "logFilePath",
    "ownerPassword",
    "deviceEnrollmentEnabled",
    "privateKeyPath",
    "refreshToken",
    "remoteSettingsAllowed",
    "stateFilePath",
    "systemAuthenticationEnabled"
  ],
  "platformCapabilities": {
    "macos": {
      "commandPrivileges": ["user"]
    },
    "windows": {
      "commandPrivileges": ["user", "administrator"]
    }
  },
  "fields": [
    {"key":"general.name","title":"Name","sectionId":"general","sectionTitle":"General","order":10,"editor":"text","type":"string","applyClass":"live","availability":"all","maxLength":64},
    {"key":"network.fecPercentage","title":"Forward error correction","sectionId":"network","sectionTitle":"Network","order":20,"editor":"integer-menu","type":"integer","applyClass":"next-session","availability":"all","minimum":1,"maximum":255,"presets":[5,10,15,20,25,30,40,50],"step":1,"valueLabels":{"5":"5%","10":"10%","15":"15%","20":"20%","25":"25%","30":"30%","40":"40%","50":"50%"}},
    {"key":"commands.prep","title":"Preparation commands","sectionId":"commands","sectionTitle":"Commands","order":30,"editor":"prep-command-list","type":"command-list","applyClass":"next-session","availability":"host-capability","values":["user","administrator"]},
    {"key":"commands.state","title":"State commands","sectionId":"commands","sectionTitle":"Commands","order":40,"editor":"prep-command-list","type":"command-list","applyClass":"next-session","availability":"host-capability","values":["user","administrator"]},
    {"key":"commands.server","title":"Server commands","sectionId":"commands","sectionTitle":"Commands","order":50,"editor":"server-command-list","type":"command-list","applyClass":"next-session","availability":"host-capability","values":["user","administrator"]}
  ]
}
