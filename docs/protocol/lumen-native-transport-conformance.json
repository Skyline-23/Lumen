{
  "protocol": "lumen-stream",
  "transportName": "Lumen Object Transport",
  "version": 4,
  "alpn": "lumen-stream/4",
  "sessionProtocolVersion": 4,
  "controlTransport": "quic-v1-tls-1.3",
  "mediaPlane": "quic-datagram",
  "applicationMediaEncryption": false,
  "directMediaUdp": false,
  "clientBidirectionalStreams": {
    "control": 0,
    "reliableInput": 4,
    "telemetry": 8
  },
  "hostUnidirectionalStreams": {
    "codecConfiguration": 3,
    "firstVideoBootstrap": 7,
    "videoBootstrapStride": 4,
    "clientMinimumCredit": 8
  },
  "messageLimits": {
    "controlBytes": 32768,
    "inputBytes": 32768,
    "telemetryBytes": 32768,
    "codecConfigurationBytes": 32768,
    "videoBootstrapBytes": 16777216
  },
  "hostSessionPlan": {
    "selectedVideoCapabilityField": 44,
    "maximumObjectDelayUsField": 45
  },
  "videoBootstrap": {
    "resultControlTag": 16,
    "initialGenerationId": 1,
    "periodicByDefault": false,
    "deltaAdmission": "after-hardware-decoded-result",
    "resultCodes": {
      "unspecified": 0,
      "decoded": 1,
      "decoderRejected": 2,
      "stale": 3
    }
  },
  "mediaDatagramHeader": {
    "byteOrder": "network",
    "bytes": 28,
    "fecBlockBytes": 36,
    "fields": [
      { "name": "kind", "offset": 0, "bytes": 1 },
      { "name": "flags", "offset": 1, "bytes": 1 },
      { "name": "headerBytes", "offset": 2, "bytes": 2 },
      { "name": "generationId", "offset": 4, "bytes": 4 },
      { "name": "datagramSequence", "offset": 8, "bytes": 4 },
      { "name": "objectId", "offset": 12, "bytes": 4 },
      { "name": "objectBytes", "offset": 16, "bytes": 4 },
      { "name": "captureTimestampUs", "offset": 20, "bytes": 4 },
      { "name": "shardIndex", "offset": 24, "bytes": 1 },
      { "name": "dataShards", "offset": 25, "bytes": 1 },
      { "name": "parityShards", "offset": 26, "bytes": 1 },
      { "name": "reserved", "offset": 27, "bytes": 1 }
    ]
  },
  "mediaKinds": {
    "videoDelta": 1,
    "audio": 2,
    "inputMotion": 3
  },
  "flags": {
    "parityShard": 16,
    "fecBlock": 32
  },
  "fecBlockExtension": {
    "bytes": 8,
    "fields": [
      { "name": "blockIndex", "offset": 28, "bytes": 1 },
      { "name": "blockCount", "offset": 29, "bytes": 1 },
      { "name": "reserved", "offset": 30, "bytes": 2 },
      { "name": "objectPayloadOffset", "offset": 32, "bytes": 4 }
    ]
  },
  "fec": {
    "algorithm": "systematic-reed-solomon-vandermonde-gf256",
    "fieldPolynomial": 285,
    "generator": 2,
    "maximumTotalShardsPerBlock": 256,
    "padding": "zero-pad-data-before-parity",
    "scope": "plaintext-quic-datagram-payload"
  },
  "telemetry": {
    "streamId": 8,
    "envelope": "ClientTelemetryEnvelope",
    "mediaFeedbackTag": 10,
    "sequence": "nonzero-contiguous",
    "parityStepPercentage": 5,
    "parityRangePercentage": [5, 50]
  },
  "forbiddenCompatibilityProtocols": [
    "lumen-stream/3",
    "direct-media-udp",
    "media-path-probe",
    "exporter-media-key",
    "application-aes-gcm",
    "gamestream",
    "rtsp",
    "sdp",
    "rtp",
    "enet"
  ]
}
