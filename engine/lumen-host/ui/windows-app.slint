import { AboutSlint, ComboBox, LineEdit, ScrollView, Switch } from "std-widgets.slint";

component ActionButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> enabled: true;
    callback clicked();
    height: 30px;
    border-radius: 8px;
    background: !root.enabled ? #f0f0ec : root.primary ? #1466d9 : root.danger ? #fff0ee : touch.has-hover ? #e9e9e5 : #efefeb;
    border-width: root.danger ? 1px : 0px;
    border-color: #e05b4f;
    Text {
        text: root.text;
        color: !root.enabled ? #aaa9a4 : root.primary ? #ffffff : root.danger ? #c43d32 : #22221f;
        font-size: 13px;
        font-weight: root.primary ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
    touch := TouchArea {
        enabled: root.enabled;
        clicked => { root.clicked(); }
    }
}

component FeatureRow inherits HorizontalLayout {
    in property <image> icon;
    in property <string> title;
    spacing: 10px;
    height: 22px;
    Image { source: root.icon; width: 16px; height: 16px; image-fit: contain; colorize: #5d5b56; }
    Text { text: root.title; color: #5d5b56; font-size: 13px; vertical-alignment: center; }
}

component NavigationRow inherits Rectangle {
    in property <image> icon;
    in property <string> title;
    in property <bool> selected;
    callback clicked();
    height: 34px;
    border-radius: 7px;
    background: root.selected ? #dfdfda : touch.has-hover ? #e9e9e5 : transparent;
    HorizontalLayout {
        padding-left: 10px;
        padding-right: 8px;
        spacing: 9px;
        Image { source: root.icon; width: 17px; height: 17px; image-fit: contain; }
        Text {
            text: root.title;
            color: #282724;
            font-size: 13px;
            font-weight: root.selected ? 600 : 400;
            vertical-alignment: center;
        }
    }
    touch := TouchArea { clicked => { root.clicked(); } }
}

component PageHeader inherits VerticalLayout {
    in property <string> title;
    in property <string> subtitle;
    spacing: 4px;
    height: 52px;
    vertical-stretch: 0;
    Text { text: root.title; color: #1b1b19; font-size: 30px; font-weight: 600; }
    Text { text: root.subtitle; color: #77746d; font-size: 13px; }
}

component StatusCard inherits Rectangle {
    in property <image> icon;
    in property <string> value;
    in property <string> label;
    in property <bool> ready;
    border-radius: 10px;
    border-width: 1px;
    border-color: #deddd8;
    background: #ffffff;
    height: 118px;
    width: 222px;
    horizontal-stretch: 1;
    vertical-stretch: 0;
    VerticalLayout {
        padding: 16px;
        spacing: 7px;
        alignment: start;
        Image { source: root.icon; width: 23px; height: 23px; image-fit: contain; }
        Text { text: root.value; color: #1d1d1a; font-size: 20px; font-weight: 600; }
        Text { text: root.label; color: #77746d; font-size: 12px; }
    }
}

component SectionPanel inherits Rectangle {
    in property <string> title;
    border-radius: 10px;
    border-width: 1px;
    border-color: #deddd8;
    background: #ffffff;
}

component SettingRow inherits Rectangle {
    in property <string> title;
    in property <string> detail;
    in property <bool> checked: false;
    height: root.detail == "" ? 44px : 60px;
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        spacing: 12px;
        VerticalLayout {
            spacing: 2px;
            alignment: center;
            Text { text: root.title; color: #24231f; font-size: 13px; }
            if root.detail != "": Text { text: root.detail; color: #7a7770; font-size: 11px; wrap: word-wrap; }
        }
        Switch { checked: root.checked; }
    }
}

export component LumenWindowsApp inherits Window {
    in-out property <int> auth-mode: 0;
    in-out property <int> navigation: 0;
    in property <string> owner-name: "";
    in property <int> auth-error-code: -1;
    in property <string> auth-error-detail: "";
    property <string> auth-error: root.auth-error-code == 0
        ? @tr("Check the account fields and password confirmation.")
        : root.auth-error-code == 1
        ? @tr("An owner account already exists.")
        : root.auth-error-code == 2
        ? @tr("Authentication failure.")
        : root.auth-error-code == 3
        ? @tr("The owner account could not be saved.")
        : root.auth-error-code == 4
        ? @tr("The owner account data is damaged.")
        : root.auth-error-detail;
    in property <string> host-name: "Lumen";
    in property <int> application-count: 0;
    in property <int> control-port: 47990;
    in property <[string]> application-names: [];
    in property <bool> system-authentication-enabled: false;
    in property <string> system-authentication-label: @tr("Unlock with Windows Hello");

    callback create-owner(string, string, string);
    callback login(string);
    callback lock();
    callback navigate(int);
    callback reload-applications();
    callback force-stop-stream();
    callback restart-host();
    callback quit-host();

    title: "Lumen";
    icon: @image-url("../../../icon.svg");
    min-width: 820px;
    min-height: 500px;
    preferred-width: 960px;
    preferred-height: root.auth-mode == 2 ? 620px : 588px;
    background: #fafaf7;
    default-font-family: "Segoe UI Variable";

    if root.auth-mode != 2: HorizontalLayout {
        spacing: 0px;
        hero := Rectangle {
            width: 340px;
            horizontal-stretch: 0;
            clip: true;
            background: #fffdf5;

            Rectangle {
                x: -450px;
                y: -350px;
                width: 1000px;
                height: 1000px;
                border-radius: 500px;
                background: @radial-gradient(circle, #ffc4299c 0%, #ffc4294d 40%, #ffc42900 100%);
            }
            Rectangle {
                x: -100px;
                y: -30px;
                width: 800px;
                height: 800px;
                border-radius: 400px;
                background: @radial-gradient(circle, #ff645038 0%, #ff64501c 42%, #ff645000 100%);
            }
            Rectangle {
                x: -100px;
                y: 200px;
                width: 800px;
                height: 800px;
                border-radius: 400px;
                background: @radial-gradient(circle, #38dbc32e 0%, #38dbc317 42%, #38dbc300 100%);
            }

            Image {
                source: @image-url("../../../icon.svg");
                width: 390px;
                height: 336px;
                x: 80px;
                y: 315px;
                opacity: 0.10;
                image-fit: contain;
            }

            VerticalLayout {
                padding-left: 44px;
                padding-right: 32px;
                padding-top: 32px;
                padding-bottom: 32px;
                spacing: 0px;
                HorizontalLayout {
                    height: 28px;
                    spacing: 10px;
                    Image { source: @image-url("../../../icon.svg"); width: 27px; height: 24px; image-fit: contain; }
                    Text { text: "L U M E N"; color: #171714; font-size: 17px; font-weight: 700; vertical-alignment: center; }
                }
                Rectangle { vertical-stretch: 1; background: transparent; }
                Text {
                    text: @tr("Your computer,\nready anywhere.");
                    color: #171714;
                    font-size: 36px;
                    font-weight: 600;
                }
                Rectangle { height: 14px; background: transparent; }
                Text {
                    text: @tr("Set up one owner account. Lumen keeps\nstreaming, applications, and enrolled devices\nunder your control.");
                    color: #5c5952;
                    font-size: 14px;
                }
                Rectangle { height: 22px; background: transparent; }
                VerticalLayout {
                    spacing: 10px;
                    FeatureRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/local-credentials.svg"); title: @tr("Local credentials"); }
                    FeatureRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/host-controls.svg"); title: @tr("Native host controls"); }
                    FeatureRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/remote-access.svg"); title: @tr("Remote device access"); }
                }
                Rectangle { vertical-stretch: 1; background: transparent; }
                Text { text: @tr("Credentials never leave this computer in plaintext."); color: #817e76; font-size: 11px; }
            }
        }

        Rectangle {
            background: #fffefa;
            VerticalLayout {
                Rectangle { vertical-stretch: 1; background: transparent; }
                HorizontalLayout {
                    height: root.auth-mode == 0 ? 294px : root.system-authentication-enabled ? 240px : 198px;
                    vertical-stretch: 0;
                    padding-left: 100px;
                    padding-right: 100px;
                    VerticalLayout {
                        width: 420px;
                        vertical-stretch: 0;
                        spacing: 12px;
                    HorizontalLayout {
                        height: 48px;
                        spacing: 16px;
                        Image {
                            source: root.auth-mode == 0
                                ? @image-url("../../../src_assets/common/assets/icons/ui/create-owner.svg")
                                : @image-url("../../../src_assets/common/assets/icons/ui/unlock.svg");
                            width: 24px;
                            height: 24px;
                            image-fit: contain;
                            colorize: #ed6538;
                        }
                        VerticalLayout {
                            spacing: 3px;
                            Text {
                                text: root.auth-mode == 0 ? @tr("Create the owner account") : @tr("Unlock Lumen");
                                color: #24231f;
                                font-size: 15px;
                                font-weight: 600;
                            }
                            Text {
                                text: root.auth-mode == 0
                                    ? @tr("This account controls this host, enrolled devices, and remote settings.")
                                    : @tr("Sign in to manage this host. Streaming services continue independently.");
                                color: #77746d;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }
                    }

                        if root.auth-mode == 0: VerticalLayout {
                            vertical-stretch: 0;
                            spacing: 10px;
                            owner-input := LineEdit { height: 30px; vertical-stretch: 0; placeholder-text: @tr("Owner ID"); }
                            new-password := LineEdit { height: 30px; vertical-stretch: 0; placeholder-text: @tr("Password (12 characters minimum)"); input-type: password; }
                            confirmation := LineEdit {
                                height: 30px;
                                vertical-stretch: 0;
                                placeholder-text: @tr("Confirm password");
                                input-type: password;
                                accepted => { root.create-owner(owner-input.text, new-password.text, confirmation.text); }
                            }
                            if root.auth-error != "": Rectangle {
                                height: 36px;
                                border-radius: 8px;
                                background: #fff0ed;
                                Text { x: 12px; text: root.auth-error; color: #d14c43; font-size: 11px; vertical-alignment: center; }
                            }
                            ActionButton {
                                text: @tr("Create account");
                                primary: true;
                                enabled: owner-input.text != "" && new-password.text != "" && confirmation.text != "";
                                clicked => { root.create-owner(owner-input.text, new-password.text, confirmation.text); }
                            }
                            Text {
                                text: @tr("The password is stored only as an Argon2id hash on this computer.");
                                color: #817e76;
                                font-size: 11px;
                                wrap: word-wrap;
                            }
                        }

                        if root.auth-mode == 1: VerticalLayout {
                            vertical-stretch: 0;
                            HorizontalLayout {
                                height: 26px;
                                spacing: 9px;
                                Image { source: @image-url("../../../src_assets/common/assets/icons/ui/complete.svg"); width: 16px; height: 16px; image-fit: contain; colorize: #5dcf92; }
                                Text { text: @tr("Owner account"); color: #4d4b45; font-size: 12px; vertical-alignment: center; }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Text { text: root.owner-name; color: #8b8880; font-size: 11px; vertical-alignment: center; }
                            }
                            password-input := LineEdit {
                                height: 30px;
                                vertical-stretch: 0;
                                placeholder-text: @tr("Password");
                                input-type: password;
                                accepted => { root.login(password-input.text); }
                            }
                            if root.auth-error != "": Rectangle {
                                height: 36px;
                                border-radius: 8px;
                                background: #fff0ed;
                                HorizontalLayout {
                                    padding-left: 10px;
                                    spacing: 8px;
                                    Image { source: @image-url("../../../src_assets/common/assets/icons/ui/attention.svg"); width: 14px; height: 14px; image-fit: contain; }
                                    Text { text: root.auth-error; color: #d14c43; font-size: 11px; vertical-alignment: center; }
                                }
                            }
                            ActionButton {
                                text: @tr("Sign in");
                                primary: true;
                                enabled: password-input.text != "";
                                clicked => { root.login(password-input.text); }
                            }
                            if root.system-authentication-enabled: ActionButton {
                                text: root.system-authentication-label;
                            }
                            HorizontalLayout {
                                Text { text: @tr("Forgot password?"); color: #1769c8; font-size: 12px; }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Text { text: @tr("Quit"); color: #1769c8; font-size: 12px; }
                            }
                        }
                    }
                }
                Rectangle { vertical-stretch: 1; background: transparent; }
            }
        }
    }

    if root.auth-mode == 2: HorizontalLayout {
        spacing: 0px;
        Rectangle {
            width: 210px;
            horizontal-stretch: 0;
            background: #f1f1ee;
            border-width: 0px;
            VerticalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 14px;
                padding-bottom: 12px;
                spacing: 4px;
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/overview.svg"); title: @tr("Overview"); selected: root.navigation == 0; clicked => { root.navigate(0); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/applications.svg"); title: @tr("Applications"); selected: root.navigation == 1; clicked => { root.navigate(1); } }
                Rectangle { height: 13px; background: transparent; }
                Text { text: @tr("SETTINGS"); color: #96938b; font-size: 10px; font-weight: 600; }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/unlock.svg"); title: @tr("Security"); selected: root.navigation == 2; clicked => { root.navigate(2); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/settings.svg"); title: @tr("General"); selected: root.navigation == 3; clicked => { root.navigate(3); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/current-stream.svg"); title: @tr("Streaming"); selected: root.navigation == 4; clicked => { root.navigate(4); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/host-controls.svg"); title: @tr("Audio"); selected: root.navigation == 5; clicked => { root.navigate(5); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/remote-access.svg"); title: @tr("Input"); selected: root.navigation == 6; clicked => { root.navigate(6); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/workspace.svg"); title: @tr("Network"); selected: root.navigation == 7; clicked => { root.navigate(7); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/restart.svg"); title: @tr("Advanced"); selected: root.navigation == 8; clicked => { root.navigate(8); } }
                Rectangle { height: 9px; background: transparent; }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/diagnostics.svg"); title: @tr("Diagnostics"); selected: root.navigation == 9; clicked => { root.navigate(9); } }
                NavigationRow { icon: @image-url("../../../src_assets/common/assets/icons/ui/settings.svg"); title: @tr("About"); selected: root.navigation == 10; clicked => { root.navigate(10); } }
                Rectangle { vertical-stretch: 1; background: transparent; }
                Text { text: @tr("Signed in as"); color: #99968f; font-size: 10px; }
                Text { text: root.owner-name; color: #4a4842; font-size: 12px; font-weight: 500; }
            }
        }

        Rectangle {
            background: #fafaf7;
            if root.navigation == 0: ScrollView {
                VerticalLayout {
                    padding: 28px;
                    spacing: 20px;
                    PageHeader { title: @tr("Overview"); subtitle: @tr("Host readiness and active streaming state"); }
                    HorizontalLayout {
                        height: 118px;
                        horizontal-stretch: 1;
                        vertical-stretch: 0;
                        spacing: 14px;
                        StatusCard { icon: @image-url("../../../src_assets/common/assets/icons/ui/host-runtime.svg"); value: @tr("Running"); label: @tr("Host runtime"); ready: true; }
                        StatusCard { icon: @image-url("../../../src_assets/common/assets/icons/ui/current-stream.svg"); value: @tr("Idle"); label: @tr("Current stream"); ready: false; }
                        StatusCard { icon: @image-url("../../../src_assets/common/assets/icons/ui/applications.svg"); value: "\{root.application-count}"; label: @tr("Applications"); ready: root.application-count > 0; }
                    }
                    SectionPanel {
                        height: 128px;
                        title: @tr("System access");
                        VerticalLayout {
                            padding: 14px;
                            spacing: 9px;
                            Text { text: @tr("System access"); color: #272620; font-size: 13px; font-weight: 600; }
                            HorizontalLayout {
                                height: 28px;
                                Image { source: @image-url("../../../src_assets/common/assets/icons/ui/complete.svg"); width: 17px; height: 17px; image-fit: contain; colorize: #5dcf92; }
                                Text { text: @tr("Display capture"); color: #34332e; font-size: 12px; vertical-alignment: center; }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Text { text: @tr("Managed by Windows"); color: #817e76; font-size: 11px; vertical-alignment: center; }
                            }
                            HorizontalLayout {
                                height: 28px;
                                Image { source: @image-url("../../../src_assets/common/assets/icons/ui/complete.svg"); width: 17px; height: 17px; image-fit: contain; colorize: #5dcf92; }
                                Text { text: @tr("Input control"); color: #34332e; font-size: 12px; vertical-alignment: center; }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                Text { text: @tr("Managed by Windows"); color: #817e76; font-size: 11px; vertical-alignment: center; }
                            }
                        }
                    }
                    SectionPanel {
                        height: 110px;
                        title: @tr("Host controls");
                        VerticalLayout {
                            padding: 14px;
                            spacing: 12px;
                            Text { text: @tr("Host controls"); color: #272620; font-size: 13px; font-weight: 600; }
                            HorizontalLayout {
                                spacing: 10px;
                                ActionButton { text: @tr("Reload applications"); primary: true; clicked => { root.reload-applications(); } }
                                ActionButton { text: @tr("Force Stop Stream"); danger: true; clicked => { root.force-stop-stream(); } }
                                Rectangle { horizontal-stretch: 1; background: transparent; }
                                ActionButton { text: @tr("Restart host"); clicked => { root.restart-host(); } }
                            }
                        }
                    }
                }
            }

            if root.navigation == 1: ScrollView {
                VerticalLayout {
                    padding: 28px;
                    spacing: 20px;
                    HorizontalLayout {
                        height: 52px;
                        vertical-stretch: 0;
                        PageHeader { title: @tr("Applications"); subtitle: @tr("Choose what remote clients can launch"); }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        ActionButton { width: 128px; text: @tr("Add application"); primary: true; }
                    }
                    if root.application-count == 0: Rectangle {
                        height: 210px;
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #deddd8;
                        background: #ffffff;
                        VerticalLayout {
                            alignment: center;
                            spacing: 8px;
                            Image { source: @image-url("../../../src_assets/common/assets/icons/ui/applications.svg"); width: 30px; height: 30px; image-fit: contain; }
                            Text { text: @tr("No applications"); color: #282721; font-size: 16px; font-weight: 600; horizontal-alignment: center; }
                            Text { text: @tr("Add a desktop or application entry for remote clients."); color: #77746d; font-size: 12px; horizontal-alignment: center; }
                        }
                    }
                    for app-name in root.application-names: Rectangle {
                        height: 58px;
                        border-radius: 9px;
                        border-width: 1px;
                        border-color: #deddd8;
                        background: #ffffff;
                        HorizontalLayout {
                            padding-left: 14px;
                            padding-right: 14px;
                            spacing: 12px;
                            Image { source: @image-url("../../../src_assets/common/assets/icons/ui/application.svg"); width: 22px; height: 22px; image-fit: contain; }
                            Text { text: app-name; color: #26251f; font-size: 13px; font-weight: 500; vertical-alignment: center; }
                        }
                    }
                }
            }

            if root.navigation >= 2 && root.navigation <= 8: ScrollView {
                VerticalLayout {
                    padding: 28px;
                    spacing: 18px;
                    PageHeader {
                        title: root.navigation == 2 ? @tr("Security") : root.navigation == 3 ? @tr("General") : root.navigation == 4 ? @tr("Streaming") : root.navigation == 5 ? @tr("Audio") : root.navigation == 6 ? @tr("Input") : root.navigation == 7 ? @tr("Network") : @tr("Advanced");
                        subtitle: root.navigation == 2 ? @tr("Owner access, host locking, and system authentication") : root.navigation == 3 ? @tr("Computer identity, discovery, and logging") : root.navigation == 4 ? @tr("Codec, latency, quality, and stream display behavior") : root.navigation == 5 ? @tr("Computer audio capture and device selection") : root.navigation == 6 ? @tr("Keyboard, pointer, touch, and controller forwarding") : root.navigation == 7 ? @tr("Discovery, remote access, encryption, and recovery") : @tr("Lifecycle commands and host process automation");
                    }
                    Rectangle {
                        border-radius: 10px;
                        border-width: 1px;
                        border-color: #deddd8;
                        background: #ffffff;
                        min-height: 250px;
                        VerticalLayout {
                            if root.navigation == 2: SettingRow { title: @tr("Unlock with Windows Hello"); detail: @tr("System authentication is not enabled."); checked: false; }
                            if root.navigation == 2: ActionButton { width: 110px; text: @tr("Lock now"); clicked => { root.lock(); } }
                            if root.navigation == 3: SettingRow { title: @tr("Computer name"); detail: root.host-name; }
                            if root.navigation == 3: SettingRow { title: @tr("Discoverable on the local network"); detail: ""; checked: true; }
                            if root.navigation == 5: SettingRow { title: @tr("Stream computer audio"); detail: ""; checked: true; }
                            if root.navigation == 6: SettingRow { title: @tr("Keyboard input"); detail: ""; checked: true; }
                            if root.navigation == 6: SettingRow { title: @tr("Mouse input"); detail: ""; checked: true; }
                            if root.navigation == 6: SettingRow { title: @tr("Game controller input"); detail: ""; checked: true; }
                            if root.navigation == 7: SettingRow { title: @tr("Port"); detail: "\{root.control-port}"; }
                            if root.navigation == 7: SettingRow { title: @tr("UPnP port mapping"); detail: ""; checked: false; }
                            if root.navigation == 8: SettingRow { title: @tr("Preparation commands"); detail: @tr("Configure commands that run before a streamed application starts."); }
                            if root.navigation == 8: SettingRow { title: @tr("Server commands"); detail: @tr("Commands available to connected clients."); }
                            Rectangle { vertical-stretch: 1; background: transparent; }
                        }
                    }
                    Text { text: @tr("Changes are saved automatically."); color: #85827b; font-size: 11px; }
                }
            }

            if root.navigation == 9: ScrollView {
                VerticalLayout {
                    padding: 28px;
                    spacing: 18px;
                    PageHeader { title: @tr("Diagnostics"); subtitle: @tr("Runtime state and troubleshooting information"); }
                    SectionPanel {
                        height: 170px;
                        title: @tr("Runtime");
                        VerticalLayout {
                            padding: 15px;
                            spacing: 12px;
                            Text { text: @tr("Runtime"); color: #282720; font-size: 13px; font-weight: 600; }
                            SettingRow { title: @tr("Host"); detail: root.host-name; }
                            SettingRow { title: @tr("Control port"); detail: "\{root.control-port}"; }
                        }
                    }
                    HorizontalLayout {
                        spacing: 10px;
                        ActionButton { text: @tr("Lock now"); clicked => { root.lock(); } }
                        Rectangle { horizontal-stretch: 1; background: transparent; }
                        ActionButton { text: @tr("Quit Lumen"); danger: true; clicked => { root.quit-host(); } }
                    }
                }
            }

            if root.navigation == 10: ScrollView {
                VerticalLayout {
                    padding: 28px;
                    spacing: 18px;
                    PageHeader { title: @tr("About Lumen"); subtitle: @tr("Product and third-party attribution"); }
                    SectionPanel {
                        height: 188px;
                        title: "Lumen";
                        VerticalLayout {
                            padding: 15px;
                            spacing: 8px;
                            Text { text: "Lumen"; color: #282720; font-size: 20px; font-weight: 600; }
                            Text { text: @tr("Self-hosted remote desktop streaming"); color: #77746d; font-size: 12px; }
                            Text { text: @tr("Third-party license texts are installed with the application."); color: #77746d; font-size: 11px; }
                            Rectangle { vertical-stretch: 1; background: transparent; }
                        }
                    }
                    SectionPanel {
                        height: 124px;
                        title: @tr("Slint");
                        AboutSlint { }
                    }
                }
            }
        }
    }
}
